{
  "schema_version": "1.0",
  "supported_models": [
    "gpt-5.3-codex-spark",
    "gpt-5.4-mini",
    "gpt-5.4",
    "gpt-5.5"
  ],
  "model_ladder": [
    "gpt-5.3-codex-spark",
    "gpt-5.4-mini",
    "gpt-5.4",
    "gpt-5.5"
  ],
  "default_root": {
    "model": "gpt-5.5",
    "reasoning_effort": "medium"
  },
  "roles": {
    "architect": {
      "model": "gpt-5.5",
      "default_effort": "high",
      "sandbox_mode": "read-only",
      "built_in_fallback": "explorer",
      "risk_class": "high"
    },
    "debugger": {
      "model": "gpt-5.5",
      "default_effort": "high",
      "sandbox_mode": "workspace-write",
      "built_in_fallback": "worker",
