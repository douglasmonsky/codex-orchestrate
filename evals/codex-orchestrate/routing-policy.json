  "durable_ledger_triggers": [
    "Tier 3 or Tier 4 run",
    "model fallback",
    "security/privacy/migration/auth task",
    "more than two subagents",
    "failed validation",
    "final-review blocker"
  ],
  "context_packet": {
    "schema_version": "2.0",
    "required_packet_fields": [
      "packet_id",
      "role",
      "objective",
      "scope",
      "non_goals",
      "evidence_handles",
      "allowed_actions_and_paths",
      "constraints",
      "done_condition",
      "output_budget_words",
      "context_request_rule",
      "expected_return"
    ],
    "root_only_packet_fields": [
      "model",
      "reasoning_effort",
      "runtime_type",
      "tier",
      "model_sufficiency",
      "why_model_is_sufficient",
      "preferred_concrete_model",
      "escalation_target",
      "escalation_target_if_stuck"
    ],
    "fixture_only_packet_fields": [
      "scenario_id"
    ],
    "required_context_request_fields": [
      "reason",
      "requested_handle",
      "decision_impact"
    ],
    "handle_prefixes": [
      "file:",
      "cmd:",
      "diff:",
      "ledger:",
      "artifact:",
      "scenario:"
    ],
    "role_output_budgets_words": {
      "architect": 500,
      "debugger": 500,
      "docs_writer": 300,
      "implementer": 350,
      "implementer_simple": 350,
      "implementer_strong": 350,
      "mechanic": 200,
      "migration_analyst": 500,
      "performance_investigator": 500,
      "planner": 350,
      "repo_scout": 250,
      "repo_scout_deep": 250,
      "reviewer": 400,
      "risk_controller": 350,
      "security_auditor": 500,
      "test_runner": 250,
      "test_triage": 350
    },
    "raw_dump_forbidden_keys": [
      "raw_context",
      "raw_log",
      "full_log",
      "transcript",
      "full_transcript",
      "full_repo_context"
    ],
    "raw_dump_markers": [
      "raw transcript",
      "full transcript",
      "raw log",
      "full log",
      "complete terminal output",
      "entire conversation"
    ]
  },
  "required_smoke_terms": [
    "/orchestrate",
    "codex-orchestrate",
    "model routing",
    "source of truth",
    "runtime fallback",
    "routing ledger",
    "context packet",
    "context handle",
    "context request",
    "done condition",
    "root-only routing metadata",
    "minimal packet",
    "packet id",
    "subagent lifecycle",
    "terminal exit",
    "packet repair",
    "timed-out subagent",
    "root takeover",
    "redelegate",
    "controller loop",
    "first-step classification",
    "final senior review"
  ],
  "default_smoke_scenario_ids": [
    "model-routing-smoke",
    "fallback-smoke",
    "context-packet-smoke",
    "lifecycle-smoke",
    "timeout-recovery-smoke",
    "minimal-packet-smoke"
  ],
  "smoke_scenarios": {
    "model-routing-smoke": "/orchestrate model routing smoke test",
    "fallback-smoke": "/orchestrate Custom agent TOMLs are not callable here. Still orchestrate a repo investigation and small fix.",
    "context-packet-smoke": "/orchestrate Use compact context packets and context handles for a small repo fix before asking subagents for extra context.",
    "minimal-packet-smoke": "/orchestrate Use a minimal packet where model, reasoning effort, tier, and runtime mapping stay as root-only routing metadata.",
    "context-request-smoke": "/orchestrate A subagent needs more evidence. Require a structured context request before adding more context.",
    "lifecycle-smoke": "/orchestrate Record packet id, subagent lifecycle, terminal exit, and packet repair behavior for a small delegated task.",
    "timeout-recovery-smoke": "/orchestrate An implementation subagent timed out without changes. Recover without root takeover by repairing the packet, redelegating, or escalating the same narrow objective.",
    "high-risk-security-change": "/orchestrate Change authorization behavior for this API and make sure it is safe.",
    "tier0-upgrades-to-delegation": "/orchestrate What does this repo do? Actually, inspect the code and update the README if it is stale."
  }
}
