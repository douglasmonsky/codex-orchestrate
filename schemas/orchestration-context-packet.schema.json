{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monskyskills.local/schemas/orchestration-context-packet.schema.json",
  "title": "Codex Orchestration Context Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "role",
    "objective",
    "scope",
    "non_goals",
    "evidence_handles",
    "allowed_actions_and_paths",
    "constraints",
    "done_condition",
    "output_budget_words",
    "context_request_rule",
    "expected_return"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "2.0"},
    "packet_id": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string", "minLength": 1},
    "role": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_handles": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "allowed_actions_and_paths": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "done_condition": {"type": "string", "minLength": 1},
    "output_budget_words": {"type": "integer", "minimum": 1},
    "context_request_rule": {"type": "string", "minLength": 1},
    "expected_return": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "context_requests": {
      "type": "array",
      "items": {"$ref": "#/$defs/context_request"}
    }
  },
  "$defs": {
    "context_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "requested_handle", "decision_impact"],
      "properties": {
        "reason": {"type": "string", "minLength": 1},
        "requested_handle": {"type": "string", "minLength": 1},
        "decision_impact": {"type": "string", "minLength": 1}
      }
    }
  }
}
