{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-orchestrate.local/schemas/orchestration-ledger.schema.json",
  "title": "Codex Orchestration Run Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "task_summary",
    "repo_state",
    "started_at",
    "finished_at",
    "root",
    "routing_entries",
    "escalations",
    "validation",
    "final_review",
    "residual_risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "task_summary": {
      "type": "string",
      "minLength": 1
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "branch", "starting_status", "ending_status"],
      "properties": {
        "path": {"type": "string"},
        "branch": {"type": "string"},
        "starting_status": {"type": "string"},
        "ending_status": {"type": "string"},
        "commit": {"type": "string"}
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "reasoning_effort"],
      "properties": {
        "model": {"type": "string"},
        "reasoning_effort": {"type": "string"}
      }
    },
    "routing_entries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/routing_entry"}
    },
    "context_packets": {
      "type": "array",
      "items": {"$ref": "#/$defs/context_packet"}
    },
    "subagent_lifecycle": {
      "type": "array",
      "items": {"$ref": "#/$defs/lifecycle_event"}
    },
    "escalations": {
      "type": "array",
      "items": {"$ref": "#/$defs/escalation"}
    },
    "validation": {
      "type": "array",
      "items": {"$ref": "#/$defs/validation_entry"}
    },
    "final_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewer", "evidence", "blockers"],
      "properties": {
        "status": {"enum": ["passed", "blocked", "failed"]},
        "reviewer": {"type": "string"},
        "evidence": {
          "type": "array",
          "items": {"type": "string"}
        },
        "blockers": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "usage_estimate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subagent_count": {"type": "integer", "minimum": 0},
        "models_used": {
          "type": "array",
          "items": {"type": "string"}
        },
        "notes": {"type": "string"}
      }
    },
    "fixture_expectations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lifecycle_result": {"enum": ["pass", "fail"]}
      }
    }
  },
  "$defs": {
    "routing_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "tier",
        "agent_role",
        "runtime_type",
        "intended_model",
        "actual_model",
        "reasoning_effort",
        "fallback_notes",
        "why_model_is_sufficient",
        "evidence",
        "open_risks",
        "next_decision",
        "final_review_gate"
      ],
      "properties": {
        "packet_id": {"type": "string"},
        "step": {"type": "string"},
        "tier": {"type": "string"},
        "agent_role": {"type": "string"},
        "runtime_type": {"type": "string"},
        "intended_model": {"type": "string"},
        "actual_model": {"type": "string"},
        "reasoning_effort": {"type": "string"},
        "fallback_notes": {"type": "string"},
        "why_model_is_sufficient": {"type": "string"},
        "evidence": {
          "type": "array",
          "items": {"type": "string"}
        },
        "open_risks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "next_decision": {"type": "string"},
        "final_review_gate": {"type": "string"}
      }
    },
    "context_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "role",
        "objective",
        "scope",
        "non_goals",
        "evidence_handles",
        "allowed_actions_and_paths",
        "constraints",
        "done_condition",
        "output_budget_words",
        "context_request_rule",
        "expected_return"
      ],
      "properties": {
        "schema_version": {"type": "string"},
        "packet_id": {"type": "string"},
        "scenario_id": {"type": "string"},
        "role": {"type": "string"},
        "objective": {"type": "string"},
        "scope": {
          "type": "array",
          "items": {"type": "string"}
        },
        "non_goals": {
          "type": "array",
          "items": {"type": "string"}
        },
        "evidence_handles": {
          "type": "array",
          "items": {"type": "string"}
        },
        "allowed_actions_and_paths": {
          "type": "array",
          "items": {"type": "string"}
        },
        "constraints": {
          "type": "array",
          "items": {"type": "string"}
        },
        "done_condition": {"type": "string"},
        "output_budget_words": {"type": "integer", "minimum": 1},
        "context_request_rule": {"type": "string"},
        "expected_return": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "lifecycle_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_id", "role", "event", "timestamp", "evidence"],
      "properties": {
        "packet_id": {"type": "string"},
        "role": {"type": "string"},
        "event": {"enum": ["started", "completed", "stuck", "blocked", "context-requested", "escalated", "skipped", "packet-repaired"]},
        "exit_status": {"enum": ["done", "blocked", "stuck", "out-of-scope", "context-requested"]},
        "timestamp": {"type": "string", "format": "date-time"},
        "evidence": {"type": "string"},
        "root_decision": {"type": "string"},
        "context_request": {"$ref": "#/$defs/context_request"}
      }
    },
    "context_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "requested_handle", "decision_impact"],
      "properties": {
        "reason": {"type": "string"},
        "requested_handle": {"type": "string"},
        "decision_impact": {"type": "string"}
      }
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_role", "to_role", "reason", "result"],
      "properties": {
        "from_role": {"type": "string"},
        "to_role": {"type": "string"},
        "reason": {"type": "string"},
        "result": {"type": "string"}
      }
    },
    "validation_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "result", "evidence"],
      "properties": {
        "command": {"type": "string"},
        "result": {"enum": ["passed", "failed", "skipped"]},
        "evidence": {"type": "string"}
      }
    }
  }
}
